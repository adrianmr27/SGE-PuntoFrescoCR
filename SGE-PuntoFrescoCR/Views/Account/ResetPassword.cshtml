@{
    Layout = null;
    var correo = ViewBag.ResetCorreo as string ?? "";
    var token = ViewBag.ResetToken as string ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nueva contraseña · SGE Punto Fresco</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true">
  <style>
    .auth-panel { max-width: 460px; }
    .btn-w { width: 100%; justify-content: center; padding: .7rem; font-size: .95rem; border-radius: var(--radius-md); }
    .back-link { display: inline-flex; align-items: center; gap: .4rem; color: var(--text-muted); font-size: .84rem; margin-bottom: 1.75rem; transition: color .15s; }
    .back-link:hover { color: var(--navy); }
  </style>
</head>
<body>

<div class="auth-page">
  <div class="auth-brand">
    <div class="auth-brand-logo">
      <div class="auth-brand-icon"><i class="bi bi-shop" style="font-size:2rem;" aria-hidden="true"></i></div>
      <div class="auth-brand-name">
        <h1>SGE · Punto Fresco</h1>
        <span>Sistema de Gestión Empresarial</span>
      </div>
    </div>
    <div class="auth-brand-tagline">
      <h2>Establecer nueva contraseña</h2>
      <p>Complete el formulario con una contraseña segura.</p>
    </div>
  </div>

  <div class="auth-panel">
    <a asp-controller="Account" asp-action="Login" class="back-link"><i class="bi bi-arrow-left" aria-hidden="true"></i> Volver al inicio de sesión</a>

    <div class="auth-panel-header">
      <h2>Nueva contraseña</h2>
      <p>Cuenta: <strong>@correo</strong></p>
    </div>

    @if (ViewData["Error"] != null)
    {
      <div style="background:var(--coral-light); border:1px solid rgba(255,112,118,.3); color:#c0464b; border-radius:var(--radius-sm); padding:.65rem .9rem; font-size:.84rem; margin-bottom:1rem;">
        <i class="bi bi-exclamation-circle me-1" aria-hidden="true"></i>@ViewData["Error"]
      </div>
    }

    <form method="post" asp-controller="Account" asp-action="ResetPassword" style="display:flex;flex-direction:column;gap:1rem;">
      @Html.AntiForgeryToken()
      <input type="hidden" name="correo" value="@correo" />
      <input type="hidden" name="token" value="@token" />
      <div class="form-group">
        <label class="form-label">Nueva contraseña <span>*</span></label>
        <input class="form-control" name="nuevaPassword" type="password" required minlength="8" placeholder="Mínimo 8 caracteres">
      </div>
      <button type="submit" class="btn btn-success btn-w"><i class="bi bi-shield-lock me-2" aria-hidden="true"></i>Guardar contraseña</button>
    </form>
  </div>
</div>
</body>
</html>
