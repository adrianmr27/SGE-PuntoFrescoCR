@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar Sesión · SGE Punto Fresco</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true">
  <style>
    .auth-panel { max-width: 460px; }
    .auth-form { display: flex; flex-direction: column; gap: 1rem; }
    .remember-row { display: flex; align-items: center; justify-content: space-between; }
    .link { color: var(--teal); font-weight: 600; font-size: .84rem; transition: opacity .15s; }
    .link:hover { opacity: .75; }
    .divider { display: flex; align-items: center; gap: .75rem; color: var(--text-muted); font-size: .8rem; margin: .5rem 0; }
    .divider::before, .divider::after { content:''; flex:1; height:1px; background:var(--border); }
    .btn-login { width: 100%; justify-content: center; padding: .7rem; font-size: .95rem; border-radius: var(--radius-md); }
  </style>
</head>
<body>

<div class="auth-page">
  <div class="auth-brand">
    <div class="auth-brand-logo">
      <div class="auth-brand-icon"><i class="bi bi-shop" style="font-size:2rem;" aria-hidden="true"></i></div>
      <div class="auth-brand-name">
        <h1>Punto Fresco de Costa Rica S.A.</h1>
        <span>Sistema de Gestión Empresarial</span>
      </div>
    </div>

    <div class="auth-brand-tagline">
      <h2>Gestión inteligente para su negocio</h2>
      <p>Control total de inventario, pedidos, licitaciones, finanzas y mucho más desde una sola plataforma.</p>
    </div>

    <div class="auth-brand-stats">
      <div class="auth-stat">
        <span class="auth-stat-val">100%</span>
        <span class="auth-stat-lbl">Web</span>
      </div>
      <div class="auth-stat">
        <span class="auth-stat-val">24/7</span>
        <span class="auth-stat-lbl">Disponible</span>
      </div>
    </div>
  </div>

  <div class="auth-panel">
    <div class="auth-panel-header">
      <h2>Bienvenido</h2>
      <p>Ingrese sus credenciales para acceder al sistema</p>
    </div>

    <form class="auth-form" asp-controller="Account" asp-action="Login" method="post">
      @Html.AntiForgeryToken()
      <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

      <div class="form-group">
        <label class="form-label">Nombre de usuario <span>*</span></label>
        <input class="form-control" name="usuario" id="inp-user" type="text" placeholder="Usuario" autocomplete="username" required>
      </div>

      <div class="form-group">
        <label class="form-label">Contraseña <span>*</span></label>
        <div style="position:relative;">
          <input class="form-control" name="password" id="inp-pass" type="password" placeholder="••••••••" autocomplete="current-password" style="padding-right:2.5rem;" required>
          <button type="button" onclick="togglePass()" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);font-size:1rem;cursor:pointer;" id="pass-toggle" aria-label="Mostrar u ocultar contraseña"><i class="bi bi-eye" aria-hidden="true"></i></button>
        </div>
      </div>

      <div class="remember-row">
        <label class="switch-wrap" style="font-size:.82rem; color:var(--text-secondary);">
          <div class="switch"></div>
          <span>Recordarme</span>
        </label>
        <a asp-controller="Account" asp-action="Recover" class="link">¿Olvidé mi contraseña?</a>
      </div>

      <button type="submit" class="btn btn-primary btn-login">
        <i class="bi bi-box-arrow-in-right me-2" aria-hidden="true"></i>Iniciar Sesión
      </button>

      @if (ViewData["Error"] != null)
      {
        <div style="background:var(--coral-light); border:1px solid rgba(255,112,118,.3); color:#c0464b; border-radius:var(--radius-sm); padding:.65rem .9rem; font-size:.84rem; font-weight:500;">
          <i class="bi bi-exclamation-circle me-1" aria-hidden="true"></i>@ViewData["Error"]
        </div>
      }
    </form>

    <p style="margin-top:2rem; font-size:.78rem; color:var(--text-muted); text-align:center; line-height:1.6;">
      Punto Fresco de Costa Rica S.A. · Sistema de uso interno.<br>
      Si tiene problemas de acceso contacte a soporte.
    </p>
  </div>
</div>

<script src="~/js/app.js" asp-append-version="true"></script>
<script>
  document.querySelectorAll('.switch-wrap').forEach(wrap => {
    const sw = wrap.querySelector('.switch');
    if (sw) wrap.addEventListener('click', () => sw.classList.toggle('on'));
  });

  function togglePass() {
    const inp = document.getElementById('inp-pass');
    const btn = document.getElementById('pass-toggle');
    if (inp.type === 'password') { inp.type = 'text'; btn.innerHTML = '<i class="bi bi-eye-slash" aria-hidden="true"></i>'; }
    else { inp.type = 'password'; btn.innerHTML = '<i class="bi bi-eye" aria-hidden="true"></i>'; }
  }
</script>
</body>
</html>
