@{
    Layout = null;
    var devToken = ViewBag.RecoveryToken as string;
    var email = ViewBag.RecoverEmail as string;
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recuperar Contraseña · SGE Punto Fresco</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true">
  <style>
    .auth-panel { max-width: 460px; }
    .btn-w { width: 100%; justify-content: center; padding: .7rem; font-size: .95rem; border-radius: var(--radius-md); }
    .back-link { display: inline-flex; align-items: center; gap: .4rem; color: var(--text-muted); font-size: .84rem; margin-bottom: 1.75rem; transition: color .15s; }
    .back-link:hover { color: var(--navy); }
  </style>
</head>
<body>

<div class="auth-page">
  <div class="auth-brand">
    <div class="auth-brand-logo">
      <div class="auth-brand-icon"><i class="bi bi-shop" style="font-size:2rem;" aria-hidden="true"></i></div>
      <div class="auth-brand-name">
        <h1>SGE · Punto Fresco</h1>
        <span>Sistema de Gestión Empresarial</span>
      </div>
    </div>
    <div class="auth-brand-tagline">
      <h2>Recuperación segura de acceso</h2>
      <p>Si el correo existe en el sistema, se generó un token de recuperación (válido 30 minutos).</p>
    </div>
  </div>

  <div class="auth-panel">
    <a asp-controller="Account" asp-action="Login" class="back-link"><i class="bi bi-arrow-left" aria-hidden="true"></i> Volver al inicio de sesión</a>

    @if (ViewData["Ok"] == null)
    {
      <div class="auth-panel-header">
        <h2>¿Olvidó su contraseña?</h2>
        <p>Ingrese su correo electrónico registrado.</p>
      </div>
      <form asp-controller="Account" asp-action="Recover" method="post" style="display:flex;flex-direction:column;gap:1rem;">
        @Html.AntiForgeryToken()
        <div class="form-group">
          <label class="form-label">Correo Electrónico <span>*</span></label>
          <input class="form-control" name="correo" type="email" placeholder="correo@puntofresco.cr" required>
        </div>
        <button type="submit" class="btn btn-primary btn-w"><i class="bi bi-envelope me-2" aria-hidden="true"></i>Continuar</button>
        @if (ViewData["Error"] != null)
        {
          <div style="background:var(--coral-light); border:1px solid rgba(255,112,118,.3); color:#c0464b; border-radius:var(--radius-sm); padding:.65rem .9rem; font-size:.84rem;">
            <i class="bi bi-exclamation-circle me-1" aria-hidden="true"></i>@ViewData["Error"]
          </div>
        }
      </form>
    }
    else
    {
      <div class="auth-panel-header">
        <h2>Instrucciones enviadas</h2>
        <p>Si la cuenta existe, revise su correo: recibirá un enlace seguro (válido 30 minutos). Si no ve el mensaje, revise spam o use el token en desarrollo.</p>
      </div>
      <input type="hidden" id="recover-email-store" value="@email" />
      @if (!string.IsNullOrEmpty(devToken))
      {
        <div style="background:var(--surface-alt);border-radius:var(--radius-md);padding:.75rem;margin-bottom:1rem;font-size:.75rem;word-break:break-all;">
          <strong>Desarrollo:</strong> pegue este token al restablecer:<br><code id="recovery-token">@devToken</code>
        </div>
      }
      <div class="form-group">
        <label class="form-label">Nueva contraseña <span>*</span></label>
        <input class="form-control" type="password" id="new-pass" placeholder="Mínimo 8 caracteres">
      </div>
      <div class="form-group">
        <label class="form-label">Confirmar <span>*</span></label>
        <input class="form-control" type="password" id="conf-pass">
      </div>
      <button type="button" class="btn btn-success btn-w" onclick="doReset()"><i class="bi bi-shield-lock me-2" aria-hidden="true"></i>Establecer nueva contraseña</button>
    }
  </div>
</div>

<script>
  async function doReset() {
    const email = document.getElementById('recover-email-store')?.value?.trim();
    const token = document.getElementById('recover-token-inp')?.value?.trim();
    const p1 = document.getElementById('new-pass')?.value;
    const p2 = document.getElementById('conf-pass')?.value;
    if (!email || !token) { alert('Correo o token faltante.'); return; }
    if (!p1 || p1.length < 8) { alert('La contraseña debe tener al menos 8 caracteres'); return; }
    if (p1 !== p2) { alert('Las contraseñas no coinciden'); return; }
    const res = await fetch('/api/account/reset-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ correo: email, token: token, nuevaPassword: p1 })
    });
    if (res.ok) {
      alert('Contraseña actualizada.');
      window.location.href = '@Url.Action("Login", "Account")';
    } else {
      const j = await res.json().catch(() => ({}));
      alert(j.error || 'No se pudo restablecer.');
    }
  }
</script>
</body>
</html>
