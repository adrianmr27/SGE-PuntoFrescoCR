@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cambiar contraseña · SGE Punto Fresco</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true">
  <style>
    .auth-panel { max-width: 460px; }
    .auth-form { display: flex; flex-direction: column; gap: 1rem; }
    .btn-login { width: 100%; justify-content: center; padding: .7rem; font-size: .95rem; border-radius: var(--radius-md); }
    .info-banner {
      background: rgba(93, 210, 188, 0.12);
      border: 1px solid rgba(93, 210, 188, 0.35);
      color: #1C2260;
      border-radius: var(--radius-sm);
      padding: .75rem .9rem;
      font-size: .84rem;
      line-height: 1.5;
    }
  </style>
</head>
<body>

<div class="auth-page">
  <div class="auth-brand">
    <div class="auth-brand-logo">
      <div class="auth-brand-icon"><i class="bi bi-shield-lock" style="font-size:2rem;" aria-hidden="true"></i></div>
      <div class="auth-brand-name">
        <h1>Punto Fresco de Costa Rica S.A.</h1>
        <span>Sistema de Gestión Empresarial</span>
      </div>
    </div>
    <div class="auth-brand-tagline">
      <h2>Seguridad de su cuenta</h2>
      <p>Por política del sistema, debe establecer una contraseña personal antes de continuar.</p>
    </div>
  </div>

  <div class="auth-panel">
    <div class="auth-panel-header">
      <h2>Cambiar contraseña</h2>
      <p>Establezca una contraseña personal para su cuenta</p>
    </div>

    <div class="info-banner mb-3">
      <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
      Su contraseña temporal ya no será válida después de este cambio. Use al menos 8 caracteres.
    </div>

    <form class="auth-form" asp-controller="Account" asp-action="ChangePassword" method="post">
      @Html.AntiForgeryToken()

      <div class="form-group">
        <label class="form-label">Nueva contraseña <span>*</span></label>
        <div style="position:relative;">
          <input class="form-control" name="nuevaPassword" id="inp-new" type="password" placeholder="Mínimo 8 caracteres" autocomplete="new-password" minlength="8" required style="padding-right:2.5rem;">
          <button type="button" onclick="togglePass('inp-new','toggle-new')" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);font-size:1rem;cursor:pointer;" id="toggle-new" aria-label="Mostrar u ocultar contraseña"><i class="bi bi-eye" aria-hidden="true"></i></button>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Confirmar contraseña <span>*</span></label>
        <div style="position:relative;">
          <input class="form-control" name="confirmarPassword" id="inp-confirm" type="password" placeholder="Repita la contraseña" autocomplete="new-password" minlength="8" required style="padding-right:2.5rem;">
          <button type="button" onclick="togglePass('inp-confirm','toggle-confirm')" style="position:absolute;right:.75rem;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);font-size:1rem;cursor:pointer;" id="toggle-confirm" aria-label="Mostrar u ocultar contraseña"><i class="bi bi-eye" aria-hidden="true"></i></button>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-login">
        <i class="bi bi-check-lg me-2" aria-hidden="true"></i>Guardar y continuar
      </button>

      @if (ViewData["Error"] != null)
      {
        <div style="background:var(--coral-light); border:1px solid rgba(255,112,118,.3); color:#c0464b; border-radius:var(--radius-sm); padding:.65rem .9rem; font-size:.84rem; font-weight:500;">
          <i class="bi bi-exclamation-circle me-1" aria-hidden="true"></i>@ViewData["Error"]
        </div>
      }
    </form>

    <p style="margin-top:1.5rem; font-size:.78rem; color:var(--text-muted); text-align:center;">
      <a asp-controller="Account" asp-action="Logout" class="link">Cerrar sesión</a>
    </p>
  </div>
</div>

<script>
  function togglePass(inpId, btnId) {
    const inp = document.getElementById(inpId);
    const btn = document.getElementById(btnId);
    if (inp.type === 'password') { inp.type = 'text'; btn.innerHTML = '<i class="bi bi-eye-slash" aria-hidden="true"></i>'; }
    else { inp.type = 'password'; btn.innerHTML = '<i class="bi bi-eye" aria-hidden="true"></i>'; }
  }
</script>
</body>
</html>
